#!/usr/bin/env python3
"""bin/stamp - version-stamp the static site for cache-busting.

What it does, in one pass:

1. Reads the current git short SHA + commit datetime.
2. Rewrites every <script src="coi-serviceworker.js…"> reference to append
   `?v=<sha>` so the browser sees a new SW URL on every commit. A changed
   SW URL forces Safari (and everyone else) to fetch a fresh worker, which
   re-installs and re-claims clients on the next navigation. This fixes the
   iOS bfcache trap where Safari serves the page from cache without ever
   consulting the SW - by the time the user sees the page, the SW is
   already mid-install and the next reload is fully isolated.
3. Same treatment for style.css - both <link rel="stylesheet"> and the
   <link rel="preload" as="style"> form used on index.html. GitHub Pages
   caps Cache-Control max-age at ~10 min and we can't set 'immutable', so
   filename hashing is no win over a `?v=<sha>` query string here; the
   query just flips the cached URL on every commit, forcing instant
   revalidation. Vendor files (vendor/marked-12.0.0.min.js) already
   encode the version in the filename, so they're left alone.
4. Same `?v=<sha>` treatment for the project's own ES modules - app.js,
   lesson.js, theme.js, shortcuts.js, runner.js - in both their <script
   type="module" src="…"> entry-point form and their <link
   rel="modulepreload" href="…"> hints. Without this, a stale local JS
   bundle survives across deploys until GitHub Pages' max-age expires,
   so any change to fetch-cache strategy or render logic is invisible
   to existing tabs for up to 10 min.
5. Inserts/updates a small "updated <date HH:MM UTC> · <sha>" stamp in
   the site footer, between BUILD-STAMP-START/END markers. The link points
   at the GitHub commit. Style: subtle, single line, like bellard.org.

Idempotent: re-running with the same HEAD yields no diff. Re-running after
a new commit produces a clean two-line diff per HTML file.

usage:
  bin/stamp            # stamp all known HTML files with current HEAD
  bin/stamp --check    # exit 1 if the stamp is stale (for pre-push hook)

This script has zero external deps and zero side effects beyond the file
edits. It's safe to run from a pre-commit hook, a CI step, or by hand.
"""
from __future__ import annotations

import argparse
import datetime as _dt
import json
import pathlib
import re
import subprocess
import sys

ROOT = pathlib.Path(__file__).resolve().parent.parent
HTML_FILES = ["index.html", "lesson.html", "kr.html", "antirez.html"]
REPO_URL = "https://github.com/b1tank/learnc"
DATA_FILE = "_data.json"
PARTIALS_DIR = "partials"

# Sibling ES modules to version-stamp. Anything in this list gets `?v=<sha>`
# appended to <script type="module" src="…"> and <link rel="modulepreload"
# href="…"> references. Vendor bundles (vendor/marked-…) are deliberately
# excluded - they already encode the version in the filename.
JS_MODULES = ("app.js", "lesson.js", "theme.js", "shortcuts.js", "runner.js")

STAMP_START = "<!-- BUILD-STAMP-START -->"
STAMP_END = "<!-- BUILD-STAMP-END -->"

# Generic copy-injection markers - see _data.json for rationale.
# Two flavours, sharing the same INJECT/[/INJECT] envelope so the regex is one:
#
#   1. Prose from _data.json - for short HTML fragments. Key is a dotted
#      path into the JSON tree:
#         <!-- INJECT:courses.antirez.page_intro -->
#         <p>…</p>
#         <!-- /INJECT -->
#
#   2. Partials from disk - for multi-line chrome (header chunks, footer,
#      SVG icons). Avoids JSON-escaping a screenful of HTML. Key starts
#      with `partial:` and names a file under partials/<name>.html:
#         <!-- INJECT:partial:theme-boot -->
#         …file contents…
#         <!-- /INJECT -->
#
# Unknown keys / missing files raise SystemExit. Subsequent stamp passes
# (cache-busting, build stamp) still see the injected content, so a partial
# that contains `?v=PLACEHOLDER` will get rewritten with the current SHA
# after injection - which is exactly what we want.
INJECT_RE = re.compile(
    r"<!-- INJECT:([A-Za-z0-9_.:\-]+) -->(.*?)<!-- /INJECT -->",
    re.DOTALL,
)


def load_data() -> dict:
    path = ROOT / DATA_FILE
    if not path.exists():
        return {}
    return json.loads(path.read_text())


def resolve_dotted(data: dict, key: str) -> str:
    """Walk a dotted path through nested dicts. Raises KeyError on miss."""
    node = data
    for part in key.split("."):
        if not isinstance(node, dict) or part not in node:
            raise KeyError(key)
        node = node[part]
    if not isinstance(node, str):
        raise TypeError(f"_data.json key {key!r} is not a string (got {type(node).__name__})")
    return node


def resolve_partial(name: str) -> str:
    """Load partials/<name>.html. Rejects path-traversal attempts."""
    if not re.fullmatch(r"[A-Za-z0-9_-]+", name):
        raise SystemExit(
            f"bin/stamp: partial name {name!r} must match [A-Za-z0-9_-]+"
        )
    path = ROOT / PARTIALS_DIR / f"{name}.html"
    if not path.is_file():
        raise SystemExit(f"bin/stamp: partial file not found: {path.relative_to(ROOT)}")
    # Strip trailing newline so injection doesn't add a blank line every
    # round-trip; the injector adds its own surrounding newlines.
    return path.read_text().rstrip("\n")


def inject_copy(text: str, data: dict, *, filename: str) -> str:
    """Replace each INJECT block with the matching value.

    Two key forms:
      * `partial:<name>` → contents of partials/<name>.html
      * `dotted.key`     → string at that path in _data.json

    Inserts the value verbatim between the markers, preceded and followed
    by a newline so the injected content sits on its own line(s) regardless
    of where the markers were placed. Idempotent - re-running yields no diff.
    Unknown keys/files raise; the build should be loud if state drifts.
    """
    def _sub(m: re.Match) -> str:
        key = m.group(1)
        if key.startswith("partial:"):
            value = resolve_partial(key[len("partial:"):])
        else:
            try:
                value = resolve_dotted(data, key)
            except KeyError:
                raise SystemExit(
                    f"bin/stamp: {filename}: INJECT marker references unknown key "
                    f"{key!r} (add it to {DATA_FILE} or remove the marker)"
                )
        return f"<!-- INJECT:{key} -->\n{value}\n<!-- /INJECT -->"

    return INJECT_RE.sub(_sub, text)


def git(*args: str) -> str:
    return subprocess.check_output(["git", "-C", str(ROOT), *args], text=True).strip()


def build_info() -> tuple[str, str, str]:
    """Return (short_sha, iso_attr, human).

    iso_attr is a value suitable for <time datetime="…"> (UTC, minute
    precision, trailing Z). human is what's displayed to the user
    (`YYYY-MM-DD HH:MM UTC`). Both are derived from the committer date so
    they advance monotonically with each commit (author-date jumps around
    when rebases happen).
    """
    try:
        sha = git("rev-parse", "--short=8", "HEAD")
        iso = git("log", "-1", "--format=%cI")  # 2026-05-25T05:24:02+00:00
        dt = _dt.datetime.fromisoformat(iso).astimezone(_dt.timezone.utc)
        iso_attr = dt.strftime("%Y-%m-%dT%H:%MZ")
        human = dt.strftime("%Y-%m-%d %H:%M UTC")
        return sha, iso_attr, human
    except (subprocess.CalledProcessError, FileNotFoundError, ValueError):
        return "dev", "unknown", "unknown"


def stamp_html(text: str, sha: str, iso_attr: str, human: str, data: dict, *, filename: str) -> str:
    # 0. Copy injection from _data.json - runs first so subsequent passes
    #    (cache-busting, build stamp) see the injected content. The injected
    #    blocks are static prose; they do not contain script/style references
    #    so order doesn't strictly matter, but doing it first keeps the
    #    pipeline predictable.
    text = inject_copy(text, data, filename=filename)

    # 1. coi-serviceworker.js?v=<sha>
    text = re.sub(
        r'(<script src="coi-serviceworker\.js)(\?v=[^"]*)?(">)',
        rf'\1?v={sha}\3',
        text,
    )

    # 2. style.css?v=<sha> - matches both the plain <link rel="stylesheet">
    #    form (lesson.html) and the <link rel="preload" as="style"> form
    #    used by index.html's non-blocking CSS pattern. Anchored on
    #    `href="style.css"` so we don't accidentally rewrite anything that
    #    happens to contain those bytes inside a comment or string.
    text = re.sub(
        r'(href=")style\.css(\?v=[^"]*)?(")',
        rf'\1style.css?v={sha}\3',
        text,
    )

    # 3. Project ES modules - every entry in JS_MODULES gets `?v=<sha>`
    #    appended in both <script type="module" src="…"> and <link
    #    rel="modulepreload" href="…"> contexts. The same regex handles
    #    both because we anchor on the quote + filename + optional ?v=… +
    #    closing quote.
    for mod in JS_MODULES:
        escaped = re.escape(mod)
        text = re.sub(
            rf'((?:src|href)=")({escaped})(\?v=[^"]*)?(")',
            rf'\1\2?v={sha}\4',
            text,
        )

    # 4. footer build stamp between markers - inline <span> so the whole
    #    footer fits on one row alongside the credits line. <time> carries
    #    the machine-readable ISO timestamp; visible text shows the human
    #    form including minute-precision UTC time.
    stamp_inner = (
        f'<span class="build-stamp">updated '
        f'<time datetime="{iso_attr}">{human}</time> &middot; '
        f'<a href="{REPO_URL}/commit/{sha}" rel="noopener">{sha}</a></span>'
    )
    block = f"{STAMP_START}{stamp_inner}{STAMP_END}"

    if STAMP_START in text and STAMP_END in text:
        text = re.sub(
            re.escape(STAMP_START) + r".*?" + re.escape(STAMP_END),
            block,
            text,
            count=1,
            flags=re.DOTALL,
        )
    else:
        # New footer template (single-row): insert before </p></footer>.
        # Fall back to before </footer> if the template ever drifts.
        if "</p>\n</footer>" in text:
            text = text.replace("</p>\n</footer>", f" &middot; {block}</p>\n</footer>", 1)
        else:
            text = text.replace("</footer>", f"  <p>{block}</p>\n</footer>", 1)

    return text


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--check", action="store_true",
                    help="exit 1 if any file would change (does not write)")
    args = ap.parse_args()

    sha, iso_attr, human = build_info()
    data = load_data()
    print(f"==> stamping with sha={sha} time={human}", file=sys.stderr)

    dirty = False
    for name in HTML_FILES:
        path = ROOT / name
        before = path.read_text()
        after = stamp_html(before, sha, iso_attr, human, data, filename=name)
        if before == after:
            print(f"    {name}: clean")
            continue
        if args.check:
            print(f"    {name}: STALE", file=sys.stderr)
            dirty = True
        else:
            path.write_text(after)
            print(f"    {name}: updated")

    if args.check and dirty:
        print("run bin/stamp to refresh, then commit", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
